# Supply chain defence — hardened npm configuration
#
# Add this to your project root. These settings protect against supply chain
# attacks by disabling lifecycle scripts, pinning exact versions, enforcing
# HTTPS-only registry access, and requiring packages to be at least 5 days old.

ignore-scripts=true
package-lock=true
registry=https://registry.npmjs.org/
strict-ssl=true
audit-level=low
npx-auto-install=false
save-exact=true
min-release-age=5
